# Al-Style API
ALSTYLE_API_URL=https://api.al-style.kz/api
ALSTYLE_ACCESS_TOKEN=your-alstyle-token-here

# Наценка (1.20 = 20%)
MARKUP_MULTIPLIER=1.20

# Синхронизация (минуты)
SYNC_INTERVAL_MINUTES=120

# OMarket / Kaspi XML
COMPANY_NAME=MyCompany
MERCHANT_ID=your-merchant-id
STORE_IDS=["main-store"]

# Домен (A-запись → VPS IP)
FEED_DOMAIN=pressplay.kz

# Админка — ОБЯЗАТЕЛЬНО поменять!
# SECRET_KEY: openssl rand -hex 32
ADMIN_PASSWORD=change-me-to-strong-password
SECRET_KEY=change-me-openssl-rand-hex-32

# Логи (Dozzle)
DOZZLE_USER=admin
DOZZLE_PASSWORD=your-dozzle-password
